---
import type {
  SiteAriaCopy,
  SiteDictionary,
  SiteLocale,
  SiteNavCopy,
  SiteThemeOptionsCopy,
} from '../content/site';
import { siteCopy, siteLocales } from '../content/site';

interface Props {
  nav: SiteNavCopy;
  aria: SiteAriaCopy;
  localeNames: SiteDictionary['localeNames'];
  themeOptions: SiteThemeOptionsCopy;
  currentPath?: string;
}

const { nav, aria, localeNames, themeOptions, currentPath = '/' } = Astro.props;
const isActivePath = (path: string): boolean => currentPath === path;
const localeToLang = (locale: SiteLocale): string => {
  if (locale === 'zh') {
    return 'zh-CN';
  }

  return locale;
};
const navLabels = (key: keyof SiteNavCopy): { locale: SiteLocale; lang: string; value: string }[] => (
  siteLocales.map((locale) => ({
    locale,
    lang: localeToLang(locale),
    value: siteCopy[locale].nav[key],
  }))
);
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={aria.home} data-i18n-attr="aria-label:aria.home">
